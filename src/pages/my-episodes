'use client'

import React, { useState } from 'react'
import { 
  Edit, Play, Trash2, Share2, MoreVertical, Plus 
} from 'lucide-react'

interface Episode {
  id: string
  title: string
  status: 'Draft' | 'Scheduled' | 'Published'
  publishedDate?: string
  scheduledDate?: string
  duration: string
  plays?: number
  thumbnail?: string
}

export default function EpisodeList() {
  const [episodes, setEpisodes] = useState<Episode[]>([
    {
      id: 'ep-42',
      title: 'The Future of AI in Content Creation',
      status: 'Published',
      publishedDate: '2026-07-10',
      duration: '52:18',
      plays: 12450,
      thumbnail: 'https://picsum.photos/id/1015/64/64',
    },
    {
      id: 'ep-41',
      title: 'How I Built My First 10k Subscriber Podcast',
      status: 'Published',
      publishedDate: '2026-07-03',
      duration: '38:45',
      plays: 9870,
      thumbnail: 'https://picsum.photos/id/1005/64/64',
    },
    {
      id: 'ep-43',
      title: 'Interview with Top Indie Podcasters',
      status: 'Scheduled',
      scheduledDate: '2026-07-24',
      duration: '45:00',
      plays: 0,
    },
    {
      id: 'ep-draft',
      title: 'Q&A Session – Listener Questions',
      status: 'Draft',
      duration: '32:00',
      plays: 0,
    },
  ])

  const [searchTerm, setSearchTerm] = useState('')
  const [statusFilter, setStatusFilter] = useState<'All' | 'Draft' | 'Scheduled' | 'Published'>('All')
  const [openMenuId, setOpenMenuId] = useState<string | null>(null)
  const [previewingEpisode, setPreviewingEpisode] = useState<Episode | null>(null)

  // Filtered + Sorted Episodes
  const filteredEpisodes = episodes
    .filter((ep) => {
      const matchesSearch = ep.title.toLowerCase().includes(searchTerm.toLowerCase())
      const matchesStatus = statusFilter === 'All' || ep.status === statusFilter
      return matchesSearch && matchesStatus
    })
    .sort((a, b) => {
      const dateA = a.publishedDate || a.scheduledDate || '9999-12-31'
      const dateB = b.publishedDate || b.scheduledDate || '9999-12-31'
      return dateB.localeCompare(dateA)
    })

  const counts = {
    All: episodes.length,
    Draft: episodes.filter((e) => e.status === 'Draft').length,
    Scheduled: episodes.filter((e) => e.status === 'Scheduled').length,
    Published: episodes.filter((e) => e.status === 'Published').length,
  }

  const getStatusClasses = (status: Episode['status']) => {
    if (status === 'Published') return 'bg-emerald-100 text-emerald-800 dark:bg-emerald-950 dark:text-emerald-400'
    if (status === 'Scheduled') return 'bg-sky-100 text-sky-800 dark:bg-sky-950 dark:text-sky-400'
    return 'bg-amber-100 text-amber-800 dark:bg-amber-950 dark:text-amber-400'
  }

  // === Actions ===
  const handlePublish = (id: string) => {
    setEpisodes((prev) =>
      prev.map((ep) =>
        ep.id === id
          ? {
              ...ep,
              status: 'Published',
              publishedDate: new Date().toISOString().split('T')[0],
            }
          : ep
      )
    )
    setOpenMenuId(null)
  }

  const handleDelete = (id: string) => {
    if (confirm('Delete this episode permanently?')) {
      setEpisodes((prev) => prev.filter((ep) => ep.id !== id))
    }
    setOpenMenuId(null)
  }

  const handleEdit = (id: string) => {
    window.location.href = `/episode-editor?id=${id}`
  }

  const handlePreview = (episode: Episode) => {
    setPreviewingEpisode(episode)
    setOpenMenuId(null)
  }

  const handleGetRSS = (id: string) => {
    const rssUrl = `https://afcn.com/rss/episode/${id}`
    navigator.clipboard.writeText(rssUrl)
    alert('RSS URL copied to clipboard!')
    setOpenMenuId(null)
  }

  return (
    <div className="min-h-screen bg-gray-50 dark:bg-gray-950">
      {/* Top Navigation (consistent with your existing pages) */}
      <div className="border-b bg-white dark:bg-gray-900">
        <div className="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
          <div className="flex items-center gap-8">
            <div className="font-semibold text-xl">AFCN Podcasts</div>
            <nav className="flex gap-6 text-sm">
              <a href="/my-podcasts" className="hover:text-primary">My Podcasts</a>
              <a href="/episodes" className="font-medium text-primary">Episodes</a>
            </nav>
          </div>
          <div className="flex items-center gap-3">
            <button 
              onClick={() => window.location.href = '/record-new'}
              className="flex items-center gap-2 px-4 py-2 bg-black text-white rounded-lg hover:bg-gray-800 transition-colors text-sm font-medium"
            >
              <Plus className="w-4 h-4" /> Record New Episode
            </button>
          </div>
        </div>
      </div>

      <div className="max-w-7xl mx-auto px-6 py-8">
        {/* Header */}
        <div className="flex items-end justify-between mb-8">
          <div>
            <h1 className="text-3xl font-semibold tracking-tight">Episodes</h1>
            <p className="text-muted-foreground mt-1">AFCN Daily • 4 episodes</p>
          </div>
          <button 
            onClick={() => window.location.href = '/my-podcasts'}
            className="text-sm text-muted-foreground hover:text-foreground flex items-center gap-1"
          >
            ← Back to My Podcasts
          </button>
        </div>

        {/* Filters */}
        <div className="flex flex-col sm:flex-row gap-4 mb-6">
          <div className="flex gap-2 flex-wrap">
            {(['All', 'Draft', 'Scheduled', 'Published'] as const).map((status) => (
              <button
                key={status}
                onClick={() => setStatusFilter(status)}
                className={`px-4 py-1.5 rounded-full text-sm font-medium transition-all border ${
                  statusFilter === status 
                    ? 'bg-black text-white border-black' 
                    : 'bg-white dark:bg-gray-900 border-gray-200 hover:bg-gray-50'
                }`}
              >
                {status} <span className="opacity-60">({counts[status]})</span>
              </button>
            ))}
          </div>

          <input
            type="text"
            placeholder="Search episodes..."
            value={searchTerm}
            onChange={(e) => setSearchTerm(e.target.value)}
            className="flex-1 max-w-sm px-4 py-2 border rounded-lg bg-white dark:bg-gray-900 text-sm focus:outline-none focus:ring-2 focus:ring-black/10"
          />
        </div>

        {/* Episode Table */}
        <div className="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl overflow-hidden shadow-sm">
          <table className="w-full">
            <thead className="bg-gray-50 dark:bg-gray-950 border-b">
              <tr>
                <th className="text-left px-6 py-4 font-medium text-sm">Episode</th>
                <th className="text-left px-6 py-4 font-medium text-sm w-48">Date</th>
                <th className="text-left px-6 py-4 font-medium text-sm w-28">Status</th>
                <th className="text-left px-6 py-4 font-medium text-sm w-24">Stats</th>
                <th className="text-right px-6 py-4 font-medium text-sm w-64">Actions</th>
              </tr>
            </thead>
            <tbody className="divide-y divide-gray-100 dark:divide-gray-800">
              {filteredEpisodes.length > 0 ? (
                filteredEpisodes.map((episode) => (
                  <tr key={episode.id} className="hover:bg-gray-50 dark:hover:bg-gray-950/50 group">
                    <td className="px-6 py-5">
                      <div className="flex items-center gap-4">
                        {episode.thumbnail && (
                          <img 
                            src={episode.thumbnail} 
                            alt="" 
                            className="w-12 h-12 rounded-lg object-cover border" 
                          />
                        )}
                        <div>
                          <div className="font-medium group-hover:text-primary transition-colors">
                            {episode.title}
                          </div>
                          <div className="text-xs text-muted-foreground mt-0.5">{episode.duration}</div>
                        </div>
                      </div>
                    </td>

                    <td className="px-6 py-5 text-sm text-muted-foreground">
                      {episode.publishedDate && `Published ${new Date(episode.publishedDate).toLocaleDateString()}`}
                      {episode.scheduledDate && `Scheduled for ${new Date(episode.scheduledDate).toLocaleDateString()}`}
                      {!episode.publishedDate && !episode.scheduledDate && 'Not scheduled'}
                    </td>

                    <td className="px-6 py-5">
                      <span className={`inline-flex items-center px-3 py-0.5 rounded-full text-xs font-medium ${getStatusClasses(episode.status)}`}>
                        {episode.status}
                      </span>
                    </td>

                    <td className="px-6 py-5 text-sm">
                      {episode.plays && episode.plays > 0 ? (
                        <span className="font-medium">{episode.plays.toLocaleString()} plays</span>
                      ) : (
                        <span className="text-muted-foreground">—</span>
                      )}
                    </td>

                    <td className="px-6 py-5 text-right">
                      <div className="flex items-center justify-end gap-1">
                        {/* Quick Actions */}
                        <button 
                          onClick={() => handleEdit(episode.id)}
                          className="p-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors"
                          title="Edit"
                        >
                          <Edit className="w-4 h-4" />
                        </button>
                        <button 
                          onClick={() => handlePreview(episode)}
                          className="p-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors"
                          title="Preview"
                        >
                          <Play className="w-4 h-4" />
                        </button>

                        {episode.status !== 'Published' && (
                          <button 
                            onClick={() => handlePublish(episode.id)}
                            className="px-3 py-1.5 text-xs font-medium bg-emerald-600 hover:bg-emerald-700 text-white rounded-lg transition-colors"
                          >
                            Publish
                          </button>
                        )}

                        {/* More Menu */}
                        <div className="relative">
                          <button 
                            onClick={() => setOpenMenuId(openMenuId === episode.id ? null : episode.id)}
                            className="p-2 hover:bg-gray-100 dark:hover:bg-gray-800 rounded-lg transition-colors"
                          >
                            <MoreVertical className="w-4 h-4" />
                          </button>

                          {openMenuId === episode.id && (
                            <div className="absolute right-0 mt-2 w-44 bg-white dark:bg-gray-900 border rounded-xl shadow-xl py-1 z-50">
                              <button 
                                onClick={() => handleGetRSS(episode.id)}
                                className="w-full px-4 py-2.5 text-left text-sm hover:bg-gray-50 dark:hover:bg-gray-800 flex items-center gap-2"
                              >
                                <Share2 className="w-4 h-4" /> Get RSS Feed
                              </button>
                              <button 
                                onClick={() => handleDelete(episode.id)}
                                className="w-full px-4 py-2.5 text-left text-sm text-red-600 hover:bg-red-50 dark:hover:bg-red-950/30 flex items-center gap-2"
                              >
                                <Trash2 className="w-4 h-4" /> Delete Episode
                              </button>
                            </div>
                          )}
                        </div>
                      </div>
                    </td>
                  </tr>
                ))
              ) : (
                <tr>
                  <td colSpan={5} className="px-6 py-12 text-center text-muted-foreground">
                    No episodes match your filters.
                  </td>
                </tr>
              )}
            </tbody>
          </table>
        </div>

        <div className="mt-4 text-xs text-muted-foreground flex justify-between">
          <span>Showing {filteredEpisodes.length} of {episodes.length} episodes</span>
          <span>Statuses update live • Changes are saved automatically in this demo</span>
        </div>
      </div>

      {/* Preview Modal */}
      {previewingEpisode && (
        <div 
          className="fixed inset-0 bg-black/60 flex items-center justify-center z-[100] p-4"
          onClick={() => setPreviewingEpisode(null)}
        >
          <div 
            className="bg-white dark:bg-gray-900 rounded-2xl max-w-md w-full overflow-hidden shadow-2xl"
            onClick={e => e.stopPropagation()}
          >
            <div className="p-6">
              <div className="flex justify-between items-start mb-4">
                <div>
                  <h3 className="font-semibold text-lg pr-8">{previewingEpisode.title}</h3>
                  <p className="text-sm text-muted-foreground mt-1">{previewingEpisode.duration}</p>
                </div>
                <span className={`px-3 py-0.5 rounded-full text-xs font-medium ${getStatusClasses(previewingEpisode.status)}`}>
                  {previewingEpisode.status}
                </span>
              </div>

              {/* Fake Player */}
              <div className="bg-gray-100 dark:bg-gray-800 rounded-xl p-5 mb-5">
                <div className="flex items-center gap-4">
                  <button className="w-12 h-12 flex items-center justify-center bg-white dark:bg-gray-950 rounded-full shadow">
                    ▶
                  </button>
                  <div className="flex-1">
                    <div className="h-1.5 bg-gray-300 dark:bg-gray-700 rounded-full">
                      <div className="h-1.5 w-1/3 bg-black rounded-full"></div>
                    </div>
                    <div className="flex justify-between text-[10px] text-muted-foreground mt-1.5">
                      <span>18:42</span>
                      <span>{previewingEpisode.duration}</span>
                    </div>
                  </div>
                </div>
              </div>

              <p className="text-xs text-muted-foreground">
                Preview mode. Real implementation would stream the actual audio file.
              </p>
            </div>

            <div className="border-t px-6 py-4 flex justify-end gap-3 bg-gray-50 dark:bg-gray-950">
              <button 
                onClick={() => setPreviewingEpisode(null)}
                className="px-5 py-2 text-sm rounded-lg border hover:bg-white dark:hover:bg-gray-900"
              >
                Close
              </button>
              <button 
                onClick={() => {
                  handleEdit(previewingEpisode.id)
                  setPreviewingEpisode(null)
                }}
                className="px-5 py-2 text-sm bg-black text-white rounded-lg hover:bg-gray-800"
              >
                Edit Episode
              </button>
            </div>
          </div>
        </div>
      )}
    </div>
  )
}
